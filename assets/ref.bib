@unpublished{feynman06,
    Author = {R. P. Feynman and J. M. Cline},
    Title = {Feynman lectures on the strong interactions},
    Note = {arXiv:2006.08594},
    doi = {2006.08594},
    file = {feynman06.pdf},
    abstract = {These twenty-two lectures, with exercises, comprise the extent of what was meant to be a full-year graduate-level course on the strong interactions and QCD, given at Caltech in 1987-88. The course was cut short by the illness that led to Feynman's death. Several of the lectures were finalized in collaboration with Feynman for an anticipated monograph based on the course. The others, while retaining Feynman's idiosyncrasies, are revised similarly to those he was able to check.},
}

@article{kp2023,
    title={Flood susceptibility mapping using hybrid models optimized with Artificial Bee Colony},
    author={Plataridis, K. and Mallios, Z.},
    journal={Journal of Hydrology},
    volume={624},
    pages={129961},
    year={2023},
    doi={10.1016/j.jhydrol.2023.129961},
    file={feynman39.pdf},
    abstract={Floods are the most common type of natural hazard causing economic and human losses. Mapping the susceptibility to flooding is essential for the effective management of flood risk. This paper aims to propose and evaluate four new hybrid models. The Spercheios river basin in Greece was chosen as a case study. The ensemble Random Forest (RF) and Extreme Gradient Boosting (XGBoost) algorithms were combined with the statistical methods of Frequency Ratio (FR) and Weight of Evidence (WoE). The models optimized by the metaheuristic Artificial Bee Colony (ABC) method. Flood inventory of the study (564 locations) developed by Synthetic Aperture Radar (SAR) imagery and flood archive. Flood locations associated with twelve conditioning factors and the dataset randomly split into training and testing sets (70%-30%). Feature selection was performed using the Information Gain Ratio (IGR) method. Input data for the training of the models were the results of FR and WoE. Receiver Operating Characteristic (ROC) curve and statistical metrics were carried out for the validation of the models. It was proved that all models had an AUC value>0.95 and the most precise model was WoE-RF-ABC (AUC = 0.9675). Variable importance of factors showed agricultural lowlands and artificial areas are more likely to be flooded. This study showed that these four optimized hybrid models could accurately predict flood areas prone to flooding and help the decision-makers.}
  }

@article{kp2024,
    title={Mapping flood susceptibility with PROMETHEE multi-criteria analysis method},
    author={Plataridis, K. and Mallios, Z.},
    journal={Environmental Science and Pollution Research},
    volume={31},
    number={28},
    pages={41267--41289},
    year={2024},
    doi={10.1007/s11356-024-33895-6},
    file={feynman39.pdf},
    abstract={On a global scale, flooding is the most devastating natural hazard with an increasingly negative impact on humans. It is necessary to accurately detect flood-prone areas. This research introduces and evaluates the Preference Ranking Organization METHod for Enrichment Evaluation (PROMETHEE) integrated with GIS in the field of flood susceptibility in comparison with two conventional multi-criteria decision analysis methods: analytical hierarchy process and Technique for Order of Preference by Similarity to Ideal Solution.}
}


@inproceedings{kp_2025_hha-a,
  title={Europe-LAND Toolbox: A Web-GIS Platform for Sustainable Land-Use Strategies in Europe},
  author={Plataridis, Konstantinos and
    Karakatsanis, Diamantis and
    Kontos, Yiannis and
    Stavridis, Charis and
    Katsifarakis, Lysandros and
    Mallios, Zisis and
    Theodossiou, Nicolaos},
  booktitle={16th Conference of the Hellenic Hydrotechnical Association (H.H.A.)},
  year={2025},
  doi={https://www.researchgate.net/publication/392323484_Europe-LAND_Toolbox_A_Web-GIS_Platform_for_Sustainable_Land-Use_Strategies_in_Europe},
  abstract={The Europe-LAND project (2022–2026), funded under the Horizon Europe program, aims to support the development and implementation of sustainable land-use strategies across Europe in the face of climate change and biodiversity loss. Central to the project is the creation of the Europe-LAND Toolbox, a Web-GIS decision-support platform designed to facilitate spatial analysis, modeling, and scenario exploration regarding land use, as well as the presentation of the results of relevant case studies of the project. The toolbox addresses the increasing need for evidence-based decision-making tools that integrate environmental, social, and economic parameters at multiple spatial and temporal scales. Developed under WP6, the Toolbox is a user-friendly, open-access, browser-based application built using the Leaflet JavaScript library. It integrates multiple spatial data sources and allows users to visualize, analyze, and extract geospatial outputs in the form of interactive maps, statistical tables, and technical reports. The platform provides layered access to datasets related to land use/land cover (LULC), environmental conditions, and socio-economic indicators, retrieved from sources such as Corine Land Cover, EEA, Copernicus, Eurostat, and national agencies. Special emphasis is given to data from the Integrated Administration and Control System (IACS), which offers high-resolution agricultural land-use information at the plot level. The toolbox supports user interaction with multiple types of data. Users can select regions of interest via NUTS-level filters or upload custom boundary files (e.g., shapefiles or KMLs). They can activate thematic layers, compare LULC changes over time, and perform overlay analysis to identify land-use pressures, synergies, and spatial conflicts. Functionalities include dynamic tools such as side-by-side map comparison (compare tool), time sliders, indicator calculations (e.g., urbanization rates, agricultural land loss, flood risk overlap), drawing tools, and export options. These features enable users to carry out customized, evidence-driven assessments for planning and policy-making. The Europe-LAND Toolbox is designed for a wide range of stakeholders, including policymakers, planners, researchers, NGOs, and land managers. It differs from conventional land-use platforms by offering a dynamic, scenario-based framework that integrates predictive models powered by AI, allowing users to explore future land-use trajectories. Furthermore, the toolbox promotes stakeholder empowerment through capacity-building activities, hands-on training, and the development of a Massive Open Online Course (MOOC). The platform aligns with key EU policy frameworks, including the European Green Deal, the Climate Adaptation Strategy, and the Common Agricultural Policy, ensuring relevance and long-term applicability. Its interoperability and modular design also support future expansion beyond the project’s lifetime. In conclusion, the Europe-LAND Toolbox represents a holistic, interactive, and forward-looking tool for sustainable land-use governance. It combines advanced Web-GIS functionality, integrated datasets, predictive modeling, and stakeholder co-creation, offering a unique contribution to spatially informed decision-making across Europe.},
}

@inproceedings{kp_2025_hha-b,
  title={Gap-Filling of Daily River Discharge Time Series Using Machine Learning Methods},
  author={Plataridis, Konstantinos and Kontos, Yiannis and Perifanos, Konstantinos},
  booktitle={16th Conference of the Hellenic Hydrotechnical Association (H.H.A.)},
  year={2025},
  doi={https://www.researchgate.net/publication/392323556_Gap-Filling_of_Daily_River_Discharge_Time_Series_Using_Machine_Learning_Methods},
  abstract={Complete river discharge time-series are essential for hydrological modeling, effective water management plans, and design/operation of flood-protection infrastructure. Such time-series often contain gaps due to natural or anthropogenic factors. Various methods have been used in the past to fill in these gaps. Recent approaches involve machine learning (ML). The aim of this study is the automatic gap-filling of daily discharge time-series using ML methods, not previously applied, and their performance evaluation. A river in Brazil was selected as the case study, with a rainfall–discharge correlation coefficient of 0.48, one of the highest among the available time-series from the Global Runoff Data Center. The discharge values are probably not significantly affected by human factors (e.g., dams, diversions). Available discharge data cover 1979-2008, with 15.63% missing data. Τhere are 47 gap intervals with a total duration of 1656 days, ranging from 1 to 558 days in length. Input data for training the models and gap-filling include the mean daily basin rainfall, extracted and computed from the ERA5 database, and previous discharge values. A rainfall lag time of 30d and a discharge lag time of 3d were considered. Additionally, month, season, and year were used as input features to capture any seasonal or long-term trends in discharge. ML algorithms employed were: Random Forest (RF), k-Nearest Neighbors (kNN), Support Vector Machine (SVM), eXtreme Gradient Boosting (XGB), Stochastic Gradient Descent (SGD), and Light Gradient Boosting Machine (LGB). Their performance was evaluated using various performance metrics. The methodology includes: 1. Statistical analysis of time-series gaps. 2. Creation of a control dataset by adding synthetic gaps. This process adapts to any time-series to reflect similar gap characteristics as the real ones, while also ensuring that at least one synthetic gap equals the maximum observed gap. 3. Data normalization where required. 4. Training the algorithms with all available data, excluding the artificially hidden discharge values of the control group. Hyperparameter tuning was performed using 5-fold cross-validation. The best-performing combination, based on the negative mean squared error, was selected for final prediction. 5. Prediction of synthetic gaps using a recursive method, with multiple performance metrics. 6. Prediction of actual gaps. 7. Presentation of results in tables and graphs, highlighting both real values and predictions on synthetic and actual gaps. ML methods can reliably fill gaps in daily discharge time-series with varying gap characteristics, considering rainfall alone, at least in series with high rainfall–runoff correlation. SVM achieved lowest relative error (12.66%), then kNN (18.22%) and SGD (25.44%). Nash-Sutcliffe Efficiency was 0.72 for SGD and kNN, and 0.70 for SVM. According to Kling–Gupta Efficiency, XGB performed best (0.74), then SGD (0.73), LGB (0.72), kNN (0.72). As for RMSE, SGD achieved 291.73, then kNN (292.85) and SVM (304.09). No model outperformed others across all metrics. SGD, kNN, and SVM were superior in most metrics, although tree-based models generally outperform other models. The unexpected results are perhaps due to lack of lag-times’ optimization, which together with incorporating additional input features (e.g. temperature, evapotranspiration) for improved predictions, constitute future research.},
}
@inproceedings{kp_2025_hha-c,
  title={Hydrological Model in HEC-HMS for the Digital Twin of the Aliakmon River},
  author={Mallios, Zisis and Theodossiou, Nicolaos and Plataridis, Konstantinos and Stavridis, Charis and Karakatsanis, Diamantis and Kontos, Yiannis},
  booktitle={16th Conference of the Hellenic Hydrotechnical Association (H.H.A.)},
  year={2025},
  doi={https://www.researchgate.net/publication/392337187_Hydrological_Model_in_HEC-HMS_for_the_Digital_Twin_of_the_Aliakmon_River},
  abstract={Effective water resources management is becoming increasingly critical due to climate change, population growth, and other pressures. To support informed decision-making, advanced tools like digital twins are necessary, enabling scenario analysis and predictive capabilities. This study presents the structure and operation of a digital twin for the Aliakmon River in Northern Greece, developed entirely with free software and open-access data, with a particular focus on its hydrological model built in HEC-HMS. The Aliakmon River, the longest river entirely within Greece, flows through Western Macedonia. Along its course, it features a cascade of five major reservoirs (Ilarionas, Polyphytos, Sfikia, Asomata, and Agia Varvara), which are essential for hydropower generation, irrigation of the Thessaloniki plain, and drinking water supply to the city of Thessaloniki. A key tributary, the Almopaios River, joins the Aliakmon about 40 km before its mouth, downstream of the final large dam. Water is diverted from the Agia Varvara reservoir through Canal A0, especially during summer, to irrigate crops and farmlands. A consistent flow of 2-3 m³/s is also redirected year-round for Thessaloniki's water supply. The canal also supports small hydropower facilities—Makrochori I and II—by utilizing ecological and surplus flows. Any excess inflow not used for water supply, irrigation, or ecological purposes spills over through the dam's spillways. The digital twin's core is a calibrated HEC-HMS model, running daily to produce weekly forecasts of river flow and water availability in the reservoirs. Its main goal is to optimize water resource allocation, prioritizing potable and irrigation needs, and secondarily hydropower production. Calibration employed diverse datasets: a) ERA5-Land hourly meteorological data from Copernicus, b) Reservoir hydropower production and storage data from IPTO (ADMIE), c) Flow measurements at Nisseli station from ELGO-DIMITRA, d) Irrigation demand data from the regional land reclamation board (GOEV Thessaloniki–Lagadas). In operational mode, the system integrates 7-day weather forecasts from OpenSkiron and executes a daily Python script that: i) Downloads and processes primary data, ii) Stores results in HEC-HMS-compatible DSS files, iii) Runs machine learning models to forecast reservoir inflow/outflow, storage volume, and demand fulfillment, iv) Injects these predictions into the HEC-HMS database, v) Triggers HEC-HMS to simulate weekly hydrological conditions. Model calibration was performed for the period September 2018–September 2023, while evaluation used data from September 2023 onward. Four statistical metrics were used to assess performance—RMSE, NSE, PBIAS, and R²—all indicating strong agreement with observed data. The model captured both seasonal trends and peak flow events with high accuracy. This digital twin demonstrates the feasibility and utility of an open-source, data-driven hydrological forecasting system. By automating the integration of meteorological forecasts, operational data, and machine learning outputs, it provides actionable insights for real-time water management. It also serves as a valuable tool for climate change adaptation, enabling water managers to simulate and prepare for future conditions.},
}




